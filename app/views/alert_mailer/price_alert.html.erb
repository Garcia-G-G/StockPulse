<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <style>
    body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; margin: 0; padding: 0; background-color: #f5f5f5; }
    .container { max-width: 600px; margin: 0 auto; background-color: #ffffff; border-radius: 8px; overflow: hidden; }
    .header { background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%); color: #ffffff; padding: 24px; text-align: center; }
    .header h1 { margin: 0; font-size: 24px; }
    .header .emoji { font-size: 32px; }
    .content { padding: 24px; }
    .price-table { width: 100%; border-collapse: collapse; margin: 16px 0; }
    .price-table td { padding: 8px 12px; border-bottom: 1px solid #eee; }
    .price-table td:first-child { color: #666; font-weight: 500; }
    .price-table td:last-child { text-align: right; font-weight: 600; }
    .alert-box { background-color: #fff3cd; border-left: 4px solid #ffc107; padding: 12px 16px; margin: 16px 0; border-radius: 4px; }
    .ai-box { background-color: #e8f4fd; border-left: 4px solid #2196f3; padding: 12px 16px; margin: 16px 0; border-radius: 4px; }
    .ai-box h3 { margin: 0 0 8px 0; color: #1565c0; font-size: 14px; }
    .footer { background-color: #f8f9fa; padding: 16px 24px; text-align: center; color: #999; font-size: 12px; }
    .positive { color: #28a745; }
    .negative { color: #dc3545; }
  </style>
</head>
<body>
  <div class="container">
    <div class="header">
      <div class="emoji"><%= @email_data[:emoji] %></div>
      <h1><%= @email_data[:label] || @alert.alert_type %></h1>
      <p style="margin: 8px 0 0; opacity: 0.8;"><%= @alert.symbol %> &mdash; <%= @email_data[:company] || @alert.symbol %></p>
    </div>

    <div class="content">
      <table class="price-table">
        <tr>
          <td>Precio Actual</td>
          <td>$<%= @email_data[:formatted_price] || number_with_precision(@price_data[:close], precision: 2) %></td>
        </tr>
        <% if @price_data[:change_percent] %>
        <tr>
          <td>Cambio</td>
          <td class="<%= @price_data[:change_percent].to_f >= 0 ? 'positive' : 'negative' %>">
            <%= @email_data[:formatted_change] %>
          </td>
        </tr>
        <% end %>
        <% if @price_data[:high] %>
        <tr>
          <td>M&aacute;ximo</td>
          <td>$<%= number_with_precision(@price_data[:high], precision: 2) %></td>
        </tr>
        <% end %>
        <% if @price_data[:low] %>
        <tr>
          <td>M&iacute;nimo</td>
          <td>$<%= number_with_precision(@price_data[:low], precision: 2) %></td>
        </tr>
        <% end %>
        <% if @price_data[:volume] %>
        <tr>
          <td>Volumen</td>
          <td><%= number_with_delimiter(@price_data[:volume].to_i) %></td>
        </tr>
        <% end %>
      </table>

      <div class="alert-box">
        <strong>&#x26A0;&#xFE0F; Condici&oacute;n activada:</strong><br>
        <%= @email_data[:trigger_desc] || "Alerta activada" %>
      </div>

      <% if @ai_analysis.present? && !@ai_analysis[:error] %>
      <div class="ai-box">
        <h3>&#x1F916; An&aacute;lisis IA</h3>
        <p><%= @ai_analysis[:summary] || @ai_analysis[:recommendation] || "Sin an&aacute;lisis disponible" %></p>
      </div>
      <% end %>
    </div>

    <div class="footer">
      <p>StockPulse &mdash; Monitoreo de Mercado en Tiempo Real</p>
      <p><%= Time.current.strftime("%d/%m/%Y %H:%M:%S %Z") %></p>
    </div>
  </div>
</body>
</html>
