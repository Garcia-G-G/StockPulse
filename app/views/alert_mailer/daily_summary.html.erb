<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <style>
    body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; margin: 0; padding: 0; background-color: #f5f5f5; }
    .container { max-width: 600px; margin: 0 auto; background-color: #ffffff; border-radius: 8px; overflow: hidden; }
    .header { background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%); color: #ffffff; padding: 24px; text-align: center; }
    .header h1 { margin: 0; font-size: 22px; }
    .content { padding: 24px; }
    .symbol-row { display: flex; justify-content: space-between; align-items: center; padding: 12px 0; border-bottom: 1px solid #eee; }
    .symbol-name { font-weight: 600; font-size: 16px; }
    .symbol-company { color: #666; font-size: 12px; }
    .symbol-price { text-align: right; }
    .symbol-price .price { font-weight: 600; font-size: 16px; }
    .symbol-price .change { font-size: 13px; }
    .positive { color: #28a745; }
    .negative { color: #dc3545; }
    .stats-box { background-color: #f8f9fa; padding: 16px; border-radius: 8px; margin: 16px 0; }
    .stats-box h3 { margin: 0 0 12px 0; font-size: 14px; color: #333; }
    .footer { background-color: #f8f9fa; padding: 16px 24px; text-align: center; color: #999; font-size: 12px; }
  </style>
</head>
<body>
  <div class="container">
    <div class="header">
      <h1>&#x1F4CA; Resumen Diario</h1>
      <p style="margin: 8px 0 0; opacity: 0.8;"><%= Date.current.strftime("%d de %B, %Y") %></p>
    </div>

    <div class="content">
      <% (@summary_data[:items] || []).each do |item| %>
        <div style="display: flex; justify-content: space-between; align-items: center; padding: 12px 0; border-bottom: 1px solid #eee;">
          <div>
            <div style="font-weight: 600; font-size: 16px;"><%= item[:symbol] %></div>
            <div style="color: #666; font-size: 12px;"><%= item[:company_name] %></div>
          </div>
          <div style="text-align: right;">
            <div style="font-weight: 600; font-size: 16px;">$<%= number_with_precision(item[:price], precision: 2) %></div>
            <% change_class = item[:change_pct].to_f >= 0 ? 'positive' : 'negative' %>
            <div class="<%= change_class %>" style="font-size: 13px;">
              <%= item[:change_pct].to_f >= 0 ? '+' : '' %><%= number_with_precision(item[:change_pct], precision: 2) %>%
            </div>
          </div>
        </div>
      <% end %>

      <% if @summary_data[:alerts_triggered] %>
      <div class="stats-box">
        <h3>&#x1F514; Alertas del d&iacute;a</h3>
        <p>Alertas activadas: <strong><%= @summary_data[:alerts_triggered] %></strong></p>
        <p>Notificaciones enviadas: <strong><%= @summary_data[:notifications_sent] || 0 %></strong></p>
      </div>
      <% end %>
    </div>

    <div class="footer">
      <p>StockPulse &mdash; Monitoreo de Mercado en Tiempo Real</p>
      <p><%= Time.current.strftime("%d/%m/%Y %H:%M:%S %Z") %></p>
    </div>
  </div>
</body>
</html>
