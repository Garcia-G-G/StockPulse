<div class="auth-container">
  <div class="auth-card">
    <a href="/" class="auth-logo">
      <svg viewBox="0 0 26 26" fill="none"><rect x="2" y="2" width="22" height="22" rx="6" stroke="#3B82F6" stroke-width="1.8"/><polyline points="7,17 10.5,11 15,14 20,7" stroke="#3B82F6" stroke-width="1.8" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg>
      <span>StockPulse</span>
    </a>

    <h1 class="auth-title">Welcome back</h1>
    <p class="auth-subtitle">Sign in to your dashboard</p>

    <% if flash[:notice] %><div class="auth-flash"><%= flash[:notice] %></div><% end %>
    <% if flash[:alert] %><div class="auth-errors"><%= flash[:alert] %></div><% end %>

    <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
      <div class="auth-field">
        <label class="auth-label" for="login_email">Email</label>
        <%= f.email_field :email, class: "auth-input", placeholder: "you@example.com", autofocus: true, required: true, id: "login_email" %>
      </div>
      <div class="auth-field">
        <label class="auth-label" for="login_password">Password</label>
        <%= f.password_field :password, class: "auth-input", placeholder: "Your password", autocomplete: "current-password", required: true, id: "login_password" %>
      </div>
      <div class="auth-row">
        <label class="auth-remember">
          <%= f.check_box :remember_me %> <span>Remember me</span>
        </label>
        <a href="<%= new_password_path(resource_name) %>" class="auth-forgot">Forgot password?</a>
      </div>
      <%= f.submit "Sign in", class: "auth-btn" %>
    <% end %>

    <div class="auth-links">
      Don't have an account? <a href="<%= new_registration_path(resource_name) %>">Create one</a>
    </div>
  </div>
</div>
