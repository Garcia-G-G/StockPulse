<div class="auth-page">
  <div class="auth-left">
    <a href="/" class="auth-back">← Back to home</a>
    <div class="auth-left-content">
      <h2>Welcome back.</h2>
      <p style="color:var(--text-secondary,#7E89A7);font-size:15px;line-height:1.6;margin-top:12px">Your watchlist, alerts, and AI briefings are waiting.</p>
    </div>
  </div>
  <div class="auth-right">
    <div class="auth-form-wrap">
      <h1 class="auth-title">Sign in</h1>
      <p class="auth-subtitle">Don't have an account? <a href="<%= new_registration_path(resource_name) %>">Create one</a></p>

      <% if flash[:notice] %><div class="auth-flash"><%= flash[:notice] %></div><% end %>
      <% if flash[:alert] %><div class="auth-errors"><%= flash[:alert] %></div><% end %>

      <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
        <div class="auth-field">
          <label class="auth-label">Email</label>
          <%= f.email_field :email, class: "auth-input", placeholder: "you@example.com", autofocus: true, required: true %>
        </div>
        <div class="auth-field">
          <label class="auth-label">Password</label>
          <%= f.password_field :password, class: "auth-input", placeholder: "Your password", autocomplete: "current-password", required: true %>
        </div>
        <div class="auth-row">
          <label class="auth-remember"><%= f.check_box :remember_me %> <span>Remember me</span></label>
          <a href="<%= new_password_path(resource_name) %>" class="auth-forgot">Forgot password?</a>
        </div>
        <%= f.submit "Sign in", class: "auth-btn" %>
      <% end %>
    </div>
  </div>
</div>
