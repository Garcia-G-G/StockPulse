<div class="auth-links">
  <% if controller_name == "sessions" %>
    Don't have an account? <a href="<%= new_registration_path(resource_name) %>">Sign Up</a>
    <br><a href="<%= new_password_path(resource_name) %>">Forgot password?</a>
  <% elsif controller_name == "registrations" %>
    Already have an account? <a href="<%= new_session_path(resource_name) %>">Sign In</a>
  <% elsif controller_name == "passwords" %>
    <a href="<%= new_session_path(resource_name) %>">Back to Sign In</a>
  <% end %>
</div>
