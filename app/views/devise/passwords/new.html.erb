<div class="auth-page">
  <div class="auth-left">
    <a href="/" class="auth-back">← Back to home</a>
    <div class="auth-left-content">
      <h2>Forgot your password?</h2>
      <p style="color:var(--text-secondary,#7E89A7);font-size:15px;line-height:1.6;margin-top:12px">No worries. Enter your email and we'll send you a reset link.</p>
    </div>
  </div>
  <div class="auth-right">
    <div class="auth-form-wrap">
      <h1 class="auth-title">Reset password</h1>
      <p class="auth-subtitle">Remember it? <a href="<%= new_session_path(resource_name) %>">Sign in</a></p>

      <%= render "devise/shared/error_messages", resource: resource %>

      <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :post }) do |f| %>
        <div class="auth-field">
          <label class="auth-label">Email</label>
          <%= f.email_field :email, class: "auth-input", placeholder: "you@example.com", autofocus: true, required: true %>
        </div>
        <%= f.submit "Send reset link", class: "auth-btn" %>
      <% end %>
    </div>
  </div>
</div>
