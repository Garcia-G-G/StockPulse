<%= turbo_frame_tag dom_id(item) do %>
  <div class="bg-white rounded-lg shadow p-4 border border-gray-200" data-controller="price" data-symbol="<%= item.symbol %>">
    <div class="flex justify-between items-center">
      <div>
        <h3 class="text-lg font-semibold text-gray-900"><%= item.symbol %></h3>
        <p class="text-sm text-gray-500"><%= item.name %></p>
      </div>
      <div class="text-right">
        <p class="text-xl font-bold" data-price-target="price">--</p>
        <p class="text-sm" data-price-target="change">--</p>
      </div>
    </div>
  </div>
<% end %>
