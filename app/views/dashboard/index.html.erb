<div class="container mx-auto px-4 py-8">
  <h1 class="text-3xl font-bold text-gray-900 mb-8">StockPulse Dashboard</h1>

  <div id="watchlist" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
    <% @watchlist_items.each do |item| %>
      <%= render "watchlist_item", item: item %>
    <% end %>
  </div>
</div>

<%= turbo_stream_from "prices" %>
