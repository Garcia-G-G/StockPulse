<div class="app">
  <nav class="sb">
    <div class="sb-logo">S</div>
    <a href="/" title="Dashboard"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg></a>
    <a href="/profile" class="active" title="Profile"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg></a>
    <div class="sb-footer"><div class="cdot" style="width:6px;height:6px;margin:0 auto"></div></div>
  </nav>

  <div class="mc">
    <header class="tb">
      <div class="tb-left">
        <div class="logo"><span class="logo-dot"></span>StockPulse</div>
        <div class="tabs">
          <a class="tab" href="/">Dashboard</a>
          <a class="tab active" href="/profile">Profile</a>
        </div>
      </div>
      <div class="tb-right">
        <div style="width:28px;height:28px;border-radius:50%;background:var(--accent);display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:700;color:#fff"><%= @user.name&.first&.upcase || "U" %></div>
        <%= button_to "Logout", destroy_user_session_path, method: :delete, style: "background:none;border:none;color:var(--text-tertiary);cursor:pointer;font-size:11px;padding:4px 8px" %>
      </div>
    </header>

    <div style="flex:1;overflow-y:auto;padding:24px;max-width:640px">
      <h2 style="font-size:20px;font-weight:700;margin-bottom:20px">Profile Settings</h2>

      <% if flash[:notice] %>
        <div style="padding:12px 16px;border-radius:8px;margin-bottom:16px;background:rgba(16,185,129,0.08);border:1px solid rgba(16,185,129,0.15);font-size:13px;color:var(--gain)"><%= flash[:notice] %></div>
      <% end %>

      <%= form_with(model: @user, url: profile_path, method: :patch, local: true) do |f| %>
        <% if @user.errors.any? %>
          <div style="padding:12px 16px;border-radius:8px;margin-bottom:16px;background:rgba(244,63,94,0.08);border:1px solid rgba(244,63,94,0.15);font-size:13px;color:var(--loss)">
            <% @user.errors.full_messages.each do |msg| %><div><%= msg %></div><% end %>
          </div>
        <% end %>

        <div class="profile-section">
          <div class="profile-section-title">Basic Information</div>
          <div class="profile-field">
            <label class="profile-label">Name</label>
            <%= f.text_field :name, class: "profile-input" %>
          </div>
          <div class="profile-field">
            <label class="profile-label">Email</label>
            <input type="email" class="profile-input" value="<%= @user.email %>" disabled style="opacity:0.6">
            <div style="font-size:11px;color:var(--text-muted);margin-top:4px">Change email via <a href="<%= edit_user_registration_path %>" style="color:var(--accent)">account settings</a></div>
          </div>
        </div>

        <div class="profile-section">
          <div class="profile-section-title">Notification Channels</div>
          <div class="profile-field">
            <label class="profile-label">Telegram Chat ID</label>
            <%= f.text_field :telegram_chat_id, class: "profile-input", placeholder: "Optional" %>
          </div>
          <div class="profile-field">
            <label class="profile-label">WhatsApp Number</label>
            <%= f.tel_field :whatsapp_number, class: "profile-input", placeholder: "+1234567890" %>
          </div>
        </div>

        <div style="margin-top:4px">
          <%= f.submit "Save Changes", class: "auth-btn", style: "max-width:200px" %>
        </div>
      <% end %>

      <div class="profile-section" style="margin-top:24px">
        <div class="profile-section-title">Password</div>
        <div style="font-size:13px;color:var(--text-secondary)">
          <a href="<%= edit_user_registration_path %>" style="color:var(--accent);text-decoration:none">Change your password →</a>
        </div>
      </div>

      <div class="profile-section danger-zone">
        <div class="profile-section-title">Danger Zone</div>
        <div style="font-size:13px;color:var(--text-secondary);margin-bottom:12px">Permanently delete your account and all data.</div>
        <%= button_to "Delete Account", user_registration_path, method: :delete, class: "auth-btn", style: "max-width:200px;background:linear-gradient(135deg,var(--loss),#dc2626);box-shadow:0 2px 20px rgba(244,63,94,0.2)", data: { turbo_confirm: "Are you sure? This cannot be undone." } %>
      </div>
    </div>
  </div>
</div>
