<%# Background — pure CSS, zero JavaScript. Runs on GPU compositor thread. %>
<div class="grid-bg"></div>
<div class="bg-aurora">
  <div class="aurora-band aurora-band-1"></div>
  <div class="aurora-band aurora-band-2"></div>
  <div class="aurora-band aurora-band-3"></div>
</div>
<div class="orb orb-1"></div>
<div class="orb orb-3"></div>

<%# Navigation %>
<nav class="landing-nav" data-controller="landing--nav-scroll">
  <a href="/" class="nav-logo">
    <svg viewBox="0 0 26 26" fill="none"><rect x="2" y="2" width="22" height="22" rx="6" stroke="url(#lg)" stroke-width="1.8"/><polyline points="7,17 10.5,11 15,14 20,7" stroke="url(#lg)" stroke-width="1.8" fill="none" stroke-linecap="round" stroke-linejoin="round"/><defs><linearGradient id="lg" x1="0" y1="0" x2="26" y2="26"><stop stop-color="#3B82F6"/><stop offset="1" stop-color="#6366F1"/></linearGradient></defs></svg>
    <span>StockPulse</span><span class="nav-live"><span class="nav-live-dot"></span>Live</span>
  </a>
  <div class="nav-links">
    <a href="#features">Features</a>
    <a href="#how">How it works</a>
    <a href="#ai">AI</a>
    <a href="<%= new_user_registration_path %>" class="nav-cta" style="background:#3B82F6;color:#fff">Get Started</a>
  </div>
</nav>

<%# Ticker Bar %>
<div class="ticker-bar" data-controller="landing--ticker">
  <div class="ticker-track" data-landing--ticker-target="track"></div>
</div>

<%# Hero %>
<section class="hero" data-controller="landing--reveal">
  <h1 class="rv">The market never sleeps.<br><span class="gradient-word">Neither does your edge.</span></h1>
  <p class="rv rv-d1">Real-time data across 8,400+ assets. AI-powered alerts. Sub-second execution. Built for traders who take this seriously.</p>
  <div class="hero-search rv rv-d2" data-controller="landing--search">
    <svg class="hero-search-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
    <input type="text" class="hero-search-input" placeholder="Search any stock, crypto, or forex — no signup needed" data-landing--search-target="input" data-action="input->landing--search#onInput focus->landing--search#onFocus">
    <div class="search-results" data-landing--search-target="results">
      <div data-landing--search-target="list"></div>
    </div>
  </div>
  <div class="hero-actions rv rv-d3">
    <a href="<%= new_user_registration_path %>" class="btn-primary">Start trading smarter</a>
    <a href="#features" class="btn-secondary">See how it works</a>
  </div>

  <div class="hero-preview rv rv-d3">
    <div class="preview-frame">
      <div class="preview-topbar">
        <div class="preview-dots"><span></span><span></span><span></span></div>
        <div class="preview-url">app.stockpulse.io/dashboard</div>
      </div>
      <div class="preview-body">
        <div class="preview-panel" data-controller="landing--portfolio-chart">
          <div class="panel-header">
            <span class="panel-title">Portfolio · 24H</span>
          </div>
          <div class="panel-value" data-landing--portfolio-chart-target="value">$24,847.32</div>
          <div class="panel-sub up" data-landing--portfolio-chart-target="change"><span class="arrow">↑</span> $1,284.50 (+5.45%)</div>
          <div class="chart-area"><canvas data-landing--portfolio-chart-target="canvas"></canvas></div>
        </div>
        <div class="preview-panel" data-controller="landing--watchlist">
          <div class="panel-header"><span class="panel-title">Watchlist</span></div>
          <div data-landing--watchlist-target="list"></div>
        </div>
      </div>
    </div>
  </div>
</section>

<%# Stats %>
<div class="stats-bar" data-controller="landing--reveal">
  <div class="stats-grid">
    <div class="stat-item rv"><div class="stat-num">8,400+</div><div class="stat-label">Symbols</div></div>
    <div class="stat-item rv rv-d1"><div class="stat-num">&lt; 1s</div><div class="stat-label">Latency</div></div>
    <div class="stat-item rv rv-d2"><div class="stat-num">2.1M</div><div class="stat-label">Alerts / month</div></div>
    <div class="stat-item rv rv-d3"><div class="stat-num">99.97%</div><div class="stat-label">Uptime</div></div>
  </div>
</div>

<%# Trust & Security %>
<div class="trust-strip" data-controller="landing--reveal">
  <div class="trust-strip-inner">
    <div class="trust-badge-item rv">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#10B981" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
      <span>256-bit encryption</span>
    </div>
    <div class="trust-badge-item rv rv-d1">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#10B981" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
      <span>SOC 2 Type II</span>
    </div>
    <div class="trust-badge-item rv rv-d2">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#10B981" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
      <span>Your data is never sold</span>
    </div>
    <div class="trust-sep-v"></div>
    <div class="trust-badge-item rv rv-d3">
      <span class="trust-partner">Powered by</span>
      <span class="trust-partner-logos">Finnhub · Alpaca · Google AI</span>
    </div>
  </div>
</div>

<%# Features — CSS-only visuals instead of canvas %>
<section class="features" id="features" data-controller="landing--reveal">
  <div class="section-label rv">What you get</div>
  <div class="section-title rv rv-d1">Three things, done well</div>
  <div class="features-grid stagger">
    <div class="feature-card rv">
      <div class="feature-visual fv-stream">
        <div class="fv-line"></div>
      </div>
      <div class="fc-body">
        <div class="fc-title">Live price feed</div>
        <div class="fc-desc">Alpaca and Finnhub WebSockets stream prices directly to your dashboard. Stocks, crypto, and forex in one place.</div>
      </div>
    </div>
    <div class="feature-card rv">
      <div class="feature-visual fv-bars">
        <% 16.times do |i| %>
          <div class="fv-bar" style="--i:<%= i %>;--h:<%= 20 + rand(65) %>%"></div>
        <% end %>
      </div>
      <div class="fc-body">
        <div class="fc-title">Configurable alerts</div>
        <div class="fc-desc">Set conditions on price, RSI, MACD, volume spikes, or news sentiment. Get notified via Telegram, email, or WhatsApp.</div>
      </div>
    </div>
    <div class="feature-card rv">
      <div class="feature-visual fv-dots">
        <% 8.times do |i| %>
          <div class="fv-dot" style="--i:<%= i %>"></div>
        <% end %>
      </div>
      <div class="fc-body">
        <div class="fc-title">AI market briefs</div>
        <div class="fc-desc">Gemini 2.5 Flash reads your watchlist, scans news and technicals, and writes you a plain-English briefing every morning.</div>
      </div>
    </div>
  </div>
</section>

<%# How It Works %>
<section class="how-section" id="how" data-controller="landing--reveal">
  <div class="how-inner">
    <div style="text-align:center">
      <div class="section-label rv">Setup</div>
      <div class="section-title rv rv-d1">Four steps, under a minute</div>
    </div>
    <div class="steps stagger">
      <div class="step rv"><div class="step-badge">1</div><div class="step-title">Sign up</div><div class="step-desc">Email and password. Free tier, no card.</div></div>
      <div class="step rv"><div class="step-badge">2</div><div class="step-title">Add symbols</div><div class="step-desc">Pick from 8,400+ stocks, crypto, and forex pairs.</div></div>
      <div class="step rv"><div class="step-badge">3</div><div class="step-title">Set conditions</div><div class="step-desc">Price targets, technical signals, or volume thresholds.</div></div>
      <div class="step rv"><div class="step-badge">4</div><div class="step-title">Get alerts</div><div class="step-desc">Telegram, email, or WhatsApp — your choice.</div></div>
    </div>
  </div>
</section>

<%# AI Section %>
<section class="ai-section" id="ai" data-controller="landing--reveal landing--ai-terminal">
  <div class="ai-grid">
    <div>
      <div class="section-label rv">Analysis</div>
      <div class="section-title rv rv-d1">AI that reads<br>the market for you</div>
      <div class="section-desc rv rv-d2">Gemini 2.5 Flash processes news, earnings, and technical patterns. You get a plain-English summary — not a wall of charts.</div>
    </div>
    <div class="ai-terminal rv rv-d3">
      <div class="ai-bar"><div class="dots"><span></span><span></span><span></span></div><div class="tag">Gemini 2.5 Flash</div></div>
      <div class="ai-body" data-landing--ai-terminal-target="body"></div>
    </div>
  </div>
</section>

<%# Notifications %>
<section class="notif-section" data-controller="landing--reveal">
  <div class="notif-inner">
    <div class="notif-grid">
      <div>
        <div class="section-label rv">Delivery</div>
        <div class="section-title rv rv-d1">Alerts where<br>you already are</div>
        <div class="section-desc rv rv-d2">Pick the channel that fits your workflow. Most users connect Telegram — alerts arrive in under a second.</div>
      </div>
      <div class="notif-stack">
        <div class="notif-card rv"><div class="n-icon tg">✈️</div><div><div class="n-title">Telegram</div><div class="n-text">AAPL crossed $200 — price alert triggered.</div><div class="n-time">Just now</div></div></div>
        <div class="notif-card rv"><div class="n-icon em">✉️</div><div><div class="n-title">Email</div><div class="n-text">Daily digest: 3 stocks moved >5%.</div><div class="n-time">2m ago</div></div></div>
        <div class="notif-card rv"><div class="n-icon wa">💬</div><div><div class="n-title">WhatsApp</div><div class="n-text">BTC volume 4.2x average in last hour.</div><div class="n-time">8m ago</div></div></div>
      </div>
    </div>
  </div>
</section>

<%# Social Proof %>
<section class="social-proof" data-controller="landing--reveal">
  <div class="social-proof-inner">
    <div class="proof-quote rv">"I replaced three paid tools with StockPulse. The Telegram alerts alone saved me — caught a 12% move before my Bloomberg terminal even updated."</div>
    <div class="proof-author rv rv-d1">— @trader_mike · verified user since Jan 2026</div>
  </div>
</section>

<%# CTA %>
<section class="cta" data-controller="landing--reveal">
  <h2 class="rv">Start for free</h2>
  <p class="rv rv-d1">Free tier includes real-time data, 5 alerts, and daily AI briefings. No credit card.</p>
  <div class="rv rv-d2" style="text-align:center">
    <a href="<%= new_user_registration_path %>" class="btn-primary" style="font-size:16px;padding:16px 48px">Create account</a>
  </div>
</section>

<%# Footer %>
<footer class="landing-footer">
  <div class="footer-inner">
    <div class="footer-left">© 2026 StockPulse</div>
    <div class="footer-links"><a href="#">Privacy</a><a href="#">Terms</a><a href="#">GitHub</a></div>
  </div>
</footer>
