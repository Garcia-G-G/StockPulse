<%# Ticker — the only continuous animation %>
<div class="ticker" data-controller="landing--ticker">
  <div class="ticker-inner" data-landing--ticker-target="track"></div>
</div>

<%# Hero %>
<section class="hero" data-controller="landing--reveal">
  <h1 class="rv">Track any asset.<br><em>Real data, not promises.</em></h1>
  <p class="hero-sub rv rv-d1">Search any stock or crypto. See live prices, charts, and AI insights — no account needed.</p>

  <div class="search-wrap rv rv-d2" data-controller="landing--search">
    <svg class="search-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
    <input type="text" class="search-input" placeholder="Search any stock, crypto, or forex pair...">
    <div class="search-results"></div>
  </div>
  <div class="search-hint rv rv-d3">Try <kbd>AAPL</kbd> <kbd>BTC</kbd> <kbd>TSLA</kbd> <kbd>EUR/USD</kbd> — real-time quotes, no signup required</div>

  <%# Dashboard Preview %>
  <div class="preview-wrap rv rv-d4" style="max-width:900px">
    <div class="preview-bar">
      <div class="dot dot-r"></div><div class="dot dot-y"></div><div class="dot dot-g"></div>
      <div class="preview-url">app.stockpulse.io / AAPL</div>
    </div>
    <div class="preview-body">
      <div class="preview-left" data-controller="landing--portfolio-chart">
        <div class="label-sm">Apple Inc. · AAPL · NASDAQ</div>
        <div class="big-num">$258.90</div>
        <div class="sub-num">↑ $5.40 (+2.13%) today</div>
        <div class="chart-area">
          <div class="chart-fill"></div>
        </div>
        <div style="display:flex;gap:20px;margin-top:14px;font-size:11px;color:var(--text-muted)">
          <div>Open <span style="color:var(--text-secondary)">$258.45</span></div>
          <div>High <span style="color:var(--text-secondary)">$259.75</span></div>
          <div>Low <span style="color:var(--text-secondary)">$256.53</span></div>
          <div>Vol <span style="color:var(--text-secondary)">48.2M</span></div>
        </div>
      </div>
      <div class="preview-right" data-controller="landing--watchlist">
        <div class="label-sm">Your Watchlist</div>
        <div class="wl-item">
          <div class="wl-badge" style="background:rgba(59,130,246,0.1);color:var(--accent)">A</div>
          <div class="wl-info"><div class="wl-ticker">AAPL</div><div class="wl-name">Apple Inc.</div></div>
          <div><div class="wl-price">258.90</div><div class="wl-chg" style="color:var(--gain)">+2.13%</div></div>
        </div>
        <div class="wl-item">
          <div class="wl-badge" style="background:rgba(16,185,129,0.1);color:var(--gain)">N</div>
          <div class="wl-info"><div class="wl-ticker">NVDA</div><div class="wl-name">NVIDIA Corp.</div></div>
          <div><div class="wl-price">181.77</div><div class="wl-chg" style="color:var(--gain)">+2.06%</div></div>
        </div>
        <div class="wl-item">
          <div class="wl-badge" style="background:rgba(244,63,94,0.1);color:var(--loss)">T</div>
          <div class="wl-info"><div class="wl-ticker">TSLA</div><div class="wl-name">Tesla Inc.</div></div>
          <div><div class="wl-price">341.98</div><div class="wl-chg" style="color:var(--loss)">-1.35%</div></div>
        </div>
        <div class="wl-item">
          <div class="wl-badge" style="background:rgba(245,158,11,0.1);color:#F59E0B">B</div>
          <div class="wl-info"><div class="wl-ticker">BTC</div><div class="wl-name">Bitcoin</div></div>
          <div><div class="wl-price">71,242</div><div class="wl-chg" style="color:var(--gain)">+3.71%</div></div>
        </div>
        <div class="wl-item">
          <div class="wl-badge" style="background:rgba(99,102,241,0.1);color:#6366F1">M</div>
          <div class="wl-info"><div class="wl-ticker">META</div><div class="wl-name">Meta Platforms</div></div>
          <div><div class="wl-price">611.02</div><div class="wl-chg" style="color:var(--gain)">+6.26%</div></div>
        </div>
      </div>
    </div>
  </div>
</section>

